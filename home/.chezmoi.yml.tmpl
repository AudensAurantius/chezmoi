data:
  filesystem:
    cacheDir: {{ joinPath .chezmoi.homeDir ".cache" | quote }}
    appData: {{ joinPath .chezmoi.homeDir ".local" "share" | quote }}
    sourceDir: {{ joinPath .chezmoi.homeDir "Source" | quote }}
    tmpDir: /tmp
    venvDir: {{ joinPath .chezmoi.homeDir ".venv" | quote }}
    npmDir: {{ joinPath .chezmoi.homeDir ".npm-packages" }}
  # Preferred desktop-notification command. WSL2's D-Bus registers
  # org.freedesktop.Notifications as activatable but has no running daemon,
  # so stock `notify-send` blocks indefinitely. Under WSL, prefer
  # wsl-notify-send (Windows toast shim) if its chezmoi-managed wrapper is
  # present in source (i.e. will be installed by `chezmoi apply`); else
  # fall back to notify-send. Stat-based check avoids the init-before-apply
  # chicken-and-egg problem of using lookPath.
  notifier: {{ if (.chezmoi.kernel.osrelease | lower | contains "wsl") -}}
    {{- if stat (joinPath .chezmoi.sourceDir "dot_local/bin/executable_wsl-notify-send.tmpl") -}}
      "wsl-notify-send"
    {{- else -}}
      "notify-send"
    {{- end -}}
  {{- else -}}
    "notify-send"
  {{- end }}
  # Hosts with systemd-user lingering enabled (loginctl enable-linger).
  # Lingering lets user timers fire even when no login session is active —
  # useful for daily housekeeping timers like timew-autostop.
  enable_systemd_session_services: {{ has .chezmoi.hostname (list "voidmobile" "Blade16-MHaynes") }}
  {{- if eq .chezmoi.hostname "Blade16-MHaynes" }}
  email: "mhaynes@boldorange.com"
  gpg:
    keys:
      signing: "8C2F529921F562F5697658BE8F5BBECF8A19FE04"
  shell: zsh
  editor: nvim
  {{- else }}
  email: "antihaynes@gmail.com"
  gpg:
    keys:
      signing: "AEB43E83657EFBEDB5D61B2862716B9F210A3233"
  terminal: kitty
  shell: {{ $zsh := lookPath "zsh" }}{{ if $zsh -}}
    {{ $zsh }}{{ else -}}
    {{ lookPath "sh" }}{{ end }}
  editor: {{ if lookPath "nvim" -}}nvim
    {{- else if lookPath "vim" }}vim
    {{- else }}vi{{ end }}
  {{- end }}
