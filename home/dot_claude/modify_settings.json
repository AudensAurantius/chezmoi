#!/bin/sh
# chezmoi modify_ script: surgically set managed keys in ~/.claude/settings.json.
# Claude Code mutates this file at runtime (model, effortLevel, plugin state, etc.)
# — those keys are intentionally left untouched so /model and similar commands
# survive a chezmoi apply.
#
# Managed keys (always overwritten with the values below):
#   hooks, enabledPlugins, extraKnownMarketplaces, permissions.allow
#
# Guards:
#   1. jq must be on PATH; if missing, pass stdin through unchanged.
#   2. Empty stdin → emit '{}' as a safe bootstrap base.

set -eu

if ! command -v jq >/dev/null 2>&1; then
  echo "modify_settings.json: jq not on PATH; leaving ~/.claude/settings.json unchanged" >&2
  exec cat
fi

input="$(cat)"
[ -z "$input" ] && input='{}'

timew_cmd="timew | head -1 | grep -q '^Tracking' && echo '⚠ timew still tracking — bd-timew stop if done' || true"

# Notification hook: sentinel-aware Windows-toast dispatch (per-session opt-in).
notify_cmd="$HOME/.claude/scripts/hooks/on-notification.sh"

# SessionEnd cleanup: remove the per-session notification sentinel if present.
# Reads the hook event JSON on stdin to extract session_id; safe no-op if absent.
cleanup_cmd='sid=$(jq -r '\''.session_id // empty'\''); [ -n "$sid" ] && rm -f "$HOME/.local/state/claude/notifications/$sid.jq" || true'

printf '%s\n' "$input" | jq \
  --arg timew_cmd   "$timew_cmd" \
  --arg notify_cmd  "$notify_cmd" \
  --arg cleanup_cmd "$cleanup_cmd" \
  '.hooks = {
     "SessionEnd": [
       {"hooks": [{"type": "command", "command": $timew_cmd}]},
       {"hooks": [{"type": "command", "command": $cleanup_cmd}]}
     ],
     "Notification": [
       {"hooks": [{"type": "command", "command": $notify_cmd}]}
     ]
   } |
   .enabledPlugins = {"claude-mem@thedotmack": true} |
   .extraKnownMarketplaces = {"thedotmack": {"source": {"source": "github", "repo": "thedotmack/claude-mem"}}} |
   .permissions.allow = [
     "Bash(curl -H * ntfy.sh/*)",
     "Bash(wsl-notify-send *)"
   ]'
