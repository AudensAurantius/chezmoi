# ---------------------------------------------------------------------------
# Server-mode helpers
# ---------------------------------------------------------------------------

def _pass_entry_exists(pass_path: str) -> bool:
    return run(["pass", "show", pass_path], check=False, capture=True).returncode == 0


def _provision_pass_entry(pass_path: str) -> None:
    """Ensure a pass entry exists at pass_path; create one if not."""
    if _pass_entry_exists(pass_path):
        _root_log.info("pass entry already exists at %s", pass_path)
        return

    _root_log.info("No pass entry found at %s", pass_path)
    choice = input("Generate a random password with `pass generate`? [Y/n]: ").strip().lower()

    if choice in ("", "y", "yes"):
        # pass generate writes to the store and prints the password to the
        # terminal. --no-symbols avoids special chars that might need quoting
        # in shell contexts, though Dolt handles any password fine over the
        # MySQL wire protocol.
        run(["pass", "generate", "--no-symbols", pass_path, "32"])
        _root_log.info("Generated password stored at %s", pass_path)
    else:
        # getpass reads from /dev/tty directly (independent of stdin
        # redirection), then we hand the value to `pass insert --multiline`
        # via subprocess stdin. --multiline is the only pass insert variant
        # that reads stdin; --echo and the default both open /dev/tty and
        # cannot be piped.
        password = getpass.getpass(f"Enter password for {pass_path}: ")
        subprocess.run(
            ["pass", "insert", "--multiline", "--force", pass_path],
            input=password + "\n",
            text=True,
            check=True,
        )
        _root_log.info("Stored password at %s", pass_path)


def _update_envrc(project_path: Path, pass_path: str) -> None:
    """Append the Dolt server stanza to .envrc; idempotent."""
    envrc = project_path / ".envrc"
    stanza = _ENVRC_STANZA.format(pass_path=pass_path)

    if envrc.exists():
        content = envrc.read_text()
        if _ENVRC_MARKER in content:
            _root_log.info(".envrc already contains Dolt server stanza (not duplicated)")
            return
        envrc.write_text(content.rstrip("\n") + "\n\n" + stanza)
    else:
        envrc.write_text(stanza)

    _root_log.info("Updated %s", envrc)
    _root_log.info(
        "Run `direnv allow %s` to activate the new stanza.", project_path
    )


def cmd_init_project(
    path: Path | None,
    days: int,
    commit_cadence: str,
    no_git_ops: bool,
    install_systemd: bool,
    check_interval: str,
    server_mode: bool,
    dolt_user: str | None,
    pass_path: str | None,
) -> None:
    beads_dir = find_beads_dir(path)
    project_root = beads_dir.parent.resolve()
    project_path = str(project_root)
    _root_log.info("Initialising Beads project at %s", project_path)

    # -- Server mode pre-flight -----------------------------------------------
    if server_mode:
        if not shutil.which("dolt"):
            sys.exit(
                "bd-timew: --server requires the dolt binary on PATH. "
                "Install it (e.g. via chezmoi apply) then re-run."
            )
        effective_user = dolt_user or project_root.name.lower()
        result = run(
            ["bd", "dolt", "set", "user", effective_user],
            check=False, capture=True,
        )
        if result.returncode != 0:
            _root_log.warning(
                "bd dolt set user %s failed (may not be in server mode yet): %s",
                effective_user, result.stderr.strip(),
            )
        else:
            _root_log.info("Dolt user set to %s", effective_user)

        if not shutil.which("pass"):
            _root_log.warning(
                "pass not found on PATH; skipping .envrc password wiring. "
                "Add BEADS_DOLT_PASSWORD to .envrc manually."
            )
        else:
            effective_pass_path = pass_path
            if effective_pass_path is None:
                default_suggestion = f"beads/{project_root.name.lower()}"
                effective_pass_path = (
                    input(
                        f"pass store path for Dolt password [{default_suggestion}]: "
                    ).strip()
                    or default_suggestion
                )
            _provision_pass_entry(effective_pass_path)
            _update_envrc(project_root, effective_pass_path)

    settings: list[tuple[str, str]] = [
        ("dolt.auto-commit", "batch"),
        ("no-push", "true"),
    ]
    if no_git_ops:
        settings.append(("no-git-ops", "true"))

    for key, value in settings:
        result = run(
            ["bd", "config", "set", key, value], check=False, capture=True
        )
        if result.returncode != 0:
            _root_log.warning(
                "config set %s=%s failed: %s", key, value, result.stderr.strip()
            )
        else:
            _root_log.info("config set %s=%s", key, value)

    # Register in repos.yaml (idempotent)
    config = _load_repos_config()
    existing_paths = [r.get("path") for r in config["repos"]]
    if project_path not in existing_paths:
        config["repos"].append({
            "path": project_path,
            "commit_cadence": commit_cadence,
            "compact_days": days,
        })
        _save_repos_config(config)
        _root_log.info("Registered in %s", REPOS_CONFIG)
    else:
        _root_log.info("Already registered in %s (not duplicated)", REPOS_CONFIG)

    # Warn if the timer check interval is coarser than this repo's commit cadence
    global_interval = config["global"].get("check_interval", check_interval)
    try:
        interval_td = _parse_cadence(
            _INTERVAL_ALIASES.get(global_interval, global_interval)
        )
        repo_cadence_td = _parse_cadence(commit_cadence)
        if interval_td > repo_cadence_td:
            _root_log.warning(
                "check_interval '%s' is coarser than commit_cadence '%s' — "
                "commits for this project may be delayed",
                global_interval, commit_cadence,
            )
    except SystemExit:
        pass  # non-parseable interval string (e.g. custom OnCalendar); skip

    if not install_systemd:
        return

    # Write systemd unit files (idempotent — only if absent)
    systemd_dir = Path.home() / ".config" / "systemd" / "user"
    systemd_dir.mkdir(parents=True, exist_ok=True)
    service_path = systemd_dir / f"{SYSTEMD_SERVICE_NAME}.service"
    timer_path = systemd_dir / f"{SYSTEMD_SERVICE_NAME}.timer"
    bd_timew_path = shutil.which("bd-timew") or sys.argv[0]

    if not service_path.exists():
        service_path.write_text(
            _SERVICE_TEMPLATE.format(bd_timew_path=bd_timew_path)
        )
        _root_log.info("Wrote %s", service_path)
    else:
        _root_log.info("Service unit already exists, skipping: %s", service_path)

    if not timer_path.exists():
        config["global"]["check_interval"] = check_interval
        _save_repos_config(config)
        timer_path.write_text(
            _TIMER_TEMPLATE.format(
                check_interval=check_interval,
                service_name=SYSTEMD_SERVICE_NAME,
            )
        )
        _root_log.info("Wrote %s", timer_path)
    else:
        _root_log.info("Timer unit already exists, skipping: %s", timer_path)

    result = run(
        ["systemctl", "--user", "daemon-reload"], check=False, capture=True
    )
    if result.returncode != 0:
        _root_log.error("daemon-reload failed: %s", result.stderr.strip())
        return

    result = run(
        ["systemctl", "--user", "enable", "--now",
         f"{SYSTEMD_SERVICE_NAME}.timer"],
        check=False, capture=True,
    )
    if result.returncode != 0:
        _root_log.error("enable --now failed: %s", result.stderr.strip())
    else:
        _root_log.info("Timer enabled and started: %s.timer", SYSTEMD_SERVICE_NAME)


# ---------------------------------------------------------------------------
# run-service (systemd entrypoint)
# ---------------------------------------------------------------------------

def cmd_run_service() -> None:
    config = _load_repos_config()
    state = _load_cleanup_state()
    now = dt.datetime.now(dt.timezone.utc)

    for repo in config.get("repos", []):
        path = repo.get("path")
        if not path:
            _cleanup_log.warning("repos.yaml entry missing 'path', skipping")
            continue

        cadence_str = repo.get("commit_cadence", "1d")
        cadence = _parse_cadence(cadence_str)
        last_run_str = state.get(path, {}).get("last_run")
        last_run = (
            dt.datetime.fromisoformat(last_run_str).replace(tzinfo=dt.timezone.utc)
            if last_run_str
            else dt.datetime.min.replace(tzinfo=dt.timezone.utc)
        )

        if now - last_run < cadence:
            _cleanup_log.info(
                "%s: next cleanup in %s, skipping",
                path, cadence - (now - last_run),
            )
            continue

        _cleanup_log.info("%s: due for cleanup (cadence=%s)", path, cadence_str)
        try:
            cmd_cleanup(
                days=repo.get("compact_days", 7),
                commit=True,
                project_dir=Path(path),
            )
            state.setdefault(path, {})["last_run"] = now.isoformat()
            _save_cleanup_state(state)
        except Exception:
            _cleanup_log.exception("cleanup failed for %s", path)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    args = get_cli_arguments()
    setup_logger(
        args.loglevel,
        enable_file_handler=args.cmd in ("cleanup", "run-service"),
    )

    if args.cmd == "start":
        cmd_start(args.issue_id)
    elif args.cmd == "stop":
        cmd_stop()
    elif args.cmd == "switch":
        cmd_switch(args.issue_id)
    elif args.cmd == "status":
        cmd_status()
    elif args.cmd == "resolve":
        cmd_start(args.issue_id, dry_run=True)
    elif args.cmd == "cleanup":
        cmd_cleanup(
            args.days,
            commit=args.commit,
            project_dir=args.project_dir,
        )
    elif args.cmd == "init-project":
        cmd_init_project(
            path=args.path,
            days=args.days,
            commit_cadence=args.commit_cadence,
            no_git_ops=args.no_git_ops,
            install_systemd=args.install_systemd,
            check_interval=args.check_interval,
            server_mode=args.server,
            dolt_user=args.dolt_user,
            pass_path=args.pass_path,
        )
    elif args.cmd == "run-service":
        cmd_run_service()


if __name__ == "__main__":
    main()
