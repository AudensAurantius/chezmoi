_CLEANUP_SERVICE_TEMPLATE = """\
[Unit]
Description=bd-timew Beads cleanup (commit, compact, GC) for all registered projects
After=network.target

[Service]
Type=oneshot
ExecStart={bd_timew_path} run-service
StandardOutput=journal
StandardError=journal

