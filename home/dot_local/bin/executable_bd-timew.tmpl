#!/usr/bin/env python3
"""bd-timew: Beads + Timewarrior bridge with project lifecycle management.

Resolves a Beads issue's labels to a NetSuite (client, case, svc) billing
tuple via a per-project sidecar (.beads/bd-timew.yaml), then starts or stops
a Timewarrior interval tagged accordingly.

Also provides project maintenance commands: cleanup (daily Dolt commit,
rolling history compaction, GC) and init-project (apply preferred Beads
config and register a project for automated cleanup via a systemd user timer).

Resolution order for billing tuple (first match wins):
  1. Per-issue  case:<string>  label (escape hatch)
  2. First matching rule in  patterns:  (regex on space-joined label list)
  3.  default:  block in the sidecar
  4. Hardcoded global fallback (svc = "Technology Services")

Subcommands:
  start <id>         Claim issue + start Timewarrior interval
  stop               Stop current Timewarrior interval
  switch <id>        Stop current interval, start a new one
  status             Show active interval bead, tuple, and elapsed time
  resolve <id>       Dry-run: print resolved billing tuple only
  cleanup            Commit, compact, and GC the active Beads project
  init-project       Apply preferred Beads config; register for auto-cleanup

Examples:
  bd-timew start J121-abc
  bd-timew cleanup --days 7
  bd-timew init-project --path /home/user/Source/MyProject --install-systemd
"""
from __future__ import annotations

import argparse
import datetime as dt
import getpass
import json
import logging
import logging.handlers
import re
import shutil
import subprocess
import sys
from pathlib import Path

from rich.console import Console
from rich.logging import RichHandler

try:
    import yaml
except ModuleNotFoundError:
    sys.exit(
        "bd-timew: PyYAML not available. "
        "Install with `pip install --user pyyaml`."
    )

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

GLOBAL_SVC_DEFAULT = "Technology Services"
SYSTEMD_SERVICE_NAME = "bd-timew-cleanup"
REPOS_CONFIG = Path.home() / ".config" / "bd-timew" / "repos.yaml"
CLEANUP_STATE = Path.home() / ".cache" / "bd-timew" / "cleanup-state.json"
CLEANUP_LOG = Path.home() / ".cache" / "bd-timew" / "cleanup.log"

# Marker used to detect an existing server-mode stanza in .envrc (idempotency).
_ENVRC_MARKER = "# bd-timew: beads dolt server"
_ENVRC_STANZA = """\
# bd-timew: beads dolt server — managed by bd-timew init-project
# Re-run bd-timew init-project --server to update.
bd dolt status &>/dev/null || bd dolt start
export BEADS_DOLT_PASSWORD="$(pass show {pass_path} | head -1)"
"""

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Root logger: stderr via RichHandler (all subcommands).
_root_log = logging.getLogger("bd-timew")

# Cleanup sub-logger: propagates to root (-> stderr) and also writes to the
# rotating log file when the file handler is attached in setup_logger().
_cleanup_log = logging.getLogger("bd-timew.cleanup")


class HelpFormatter(
    argparse.RawDescriptionHelpFormatter,
    argparse.ArgumentDefaultsHelpFormatter,
):
    """Preserve description/epilog whitespace and show argument defaults."""


def setup_logger(loglevel: str, *, enable_file_handler: bool = False) -> None:
    level = getattr(logging, loglevel.upper(), logging.INFO)
    _root_log.setLevel(level)
    _root_log.addHandler(
        RichHandler(
            level=level,
            console=Console(stderr=True),
            show_path=False,
            rich_tracebacks=True,
        )
    )
    if enable_file_handler:
        CLEANUP_LOG.parent.mkdir(parents=True, exist_ok=True)
        fh = logging.handlers.RotatingFileHandler(
            CLEANUP_LOG, maxBytes=1_000_000, backupCount=3
        )
        fh.setLevel(level)
        fh.setFormatter(
            logging.Formatter("%(asctime)s %(levelname)s %(message)s")
        )
        _cleanup_log.addHandler(fh)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def get_cli_arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="bd-timew",
        description=__doc__,
        formatter_class=HelpFormatter,
    )
    parser.add_argument(
        "--loglevel", "-l",
        default="INFO",
        type=lambda v: v.strip().upper(),
        help="Logging verbosity (DEBUG, INFO, WARNING, ERROR).",
    )

    sub = parser.add_subparsers(dest="cmd", required=True)

    # -- start ---------------------------------------------------------------
    p_start = sub.add_parser(
        "start",
        help="Claim a Beads issue and start a Timewarrior interval.",
        description=(
            "Resolves the billing tuple for <issue-id>, claims it in Beads "
            "(if not already in_progress), and starts a tagged Timewarrior interval."
        ),
        formatter_class=HelpFormatter,
    )
    p_start.add_argument("issue_id", metavar="<issue-id>")

    # -- stop ----------------------------------------------------------------
    sub.add_parser(
        "stop",
        help="Stop the current Timewarrior interval.",
        formatter_class=HelpFormatter,
    )

    # -- switch --------------------------------------------------------------
    p_switch = sub.add_parser(
        "switch",
        help="Stop current interval and start a new one on <issue-id>.",
        description=(
            "Equivalent to  stop  then  start <issue-id>. Not transactional: "
            "if start fails after stop succeeds, re-run  bd-timew start <id>  to recover."
        ),
        formatter_class=HelpFormatter,
    )
    p_switch.add_argument("issue_id", metavar="<issue-id>")

    # -- status --------------------------------------------------------------
    sub.add_parser(
        "status",
        help="Show the active interval's bead, billing tuple, and elapsed time.",
        formatter_class=HelpFormatter,
    )

    # -- resolve -------------------------------------------------------------
    p_resolve = sub.add_parser(
        "resolve",
        help="Print the resolved billing tuple without starting Timewarrior.",
        description=(
            "Dry-run variant of  start. Useful for verifying tuple resolution "
            "before committing to a billing entry."
        ),
        formatter_class=HelpFormatter,
    )
    p_resolve.add_argument("issue_id", metavar="<issue-id>")

    # -- cleanup -------------------------------------------------------------
    p_cleanup = sub.add_parser(
        "cleanup",
        help="Compact Dolt history and run GC; optionally commit first.",
        description=(
            "Runs Beads maintenance for the active project (or --project-dir):\n"
            "  1. bd compact  — squash commits older than --days\n"
            "  2. bd gc       — compact journal, reclaim disk space\n\n"
            "Pass --commit to also seal pending batch writes before compacting.\n"
            "The systemd service (installed by init-project --install-systemd) "
            "always passes --commit."
        ),
        formatter_class=HelpFormatter,
        epilog=(
            "Examples:\n"
            "  bd-timew cleanup\n"
            "  bd-timew cleanup --commit\n"
            "  bd-timew cleanup --days 14 --project-dir ~/Source/Other\n"
        ),
    )
    p_cleanup.add_argument(
        "--days", type=int, default=7,
        help="Retain this many days of Dolt commit history.",
    )
    p_cleanup.add_argument(
        "--commit", action="store_true",
        help="Run  bd dolt commit  before compacting (seals pending batch writes).",
    )
    p_cleanup.add_argument(
        "--project-dir", type=Path, default=None,
        help="Project root containing .beads/. Defaults to the active Beads workspace.",
    )

    # -- init-project --------------------------------------------------------
    p_init = sub.add_parser(
        "init-project",
        help="Apply preferred Beads config and register for auto-cleanup.",
        description=(
            "Configures a Beads project with recommended settings "
            "(batch commits, no auto-push) and optionally registers it in\n"
            f"{REPOS_CONFIG}\n"
            "for the systemd cleanup timer.\n\n"
            "Idempotent: safe to re-run; existing config values and registry "
            "entries are not duplicated."
        ),
        formatter_class=HelpFormatter,
        epilog=(
            "Examples:\n"
            "  bd-timew init-project\n"
            "  bd-timew init-project --path ~/Source/Other --days 14 --no-git-ops\n"
            "  bd-timew init-project --install-systemd\n"
        ),
    )
    p_init.add_argument(
        "--path", type=Path, default=None,
        help="Project root containing .beads/. Defaults to the active Beads workspace.",
    )
    p_init.add_argument(
        "--days", type=int, default=7,
        help="Rolling history window (days) stored in repos.yaml for this project.",
    )
    p_init.add_argument(
        "--commit-cadence", type=str, default="1d",
        help="How often to commit (e.g. 1d, 7d, 12h). Stored in repos.yaml.",
    )
    p_init.add_argument(
        "--no-git-ops", action="store_true",
        help=(
            "Set no-git-ops=true in Beads config (suppress git ops on the outer "
            "repo). Recommended when .beads/ is a nested git repo."
        ),
    )
    p_init.add_argument(
        "--install-systemd", action="store_true",
        help=(
            "Write ~/.config/systemd/user/bd-timew-cleanup.{service,timer} and "
            "enable the timer. Unit files are only created if absent."
        ),
    )
    p_init.add_argument(
        "--check-interval", type=str, default="daily",
        help=(
            "systemd OnCalendar value for the timer (only used when creating "
            "the timer unit for the first time)."
        ),
    )
    p_init.add_argument(
        "--server", action=argparse.BooleanOptionalAction, default=True,
        help=(
            "Configure the project for Dolt server mode: set a project-specific "
            "Dolt user, provision a pass entry for the password, and write a "
            "direnv stanza to .envrc that starts the server on directory entry. "
            "Requires the dolt binary on PATH. Use --no-server to skip."
        ),
    )
    p_init.add_argument(
        "--dolt-user", type=str, default=None,
        help=(
            "MySQL username for the Dolt server. "
            "Defaults to the project directory name (lower-cased)."
        ),
    )
    p_init.add_argument(
        "--pass-path", type=str, default=None,
        help=(
            "pass store path for the Dolt password "
            "(e.g. 'beads/j121'). Prompted interactively if not given."
        ),
    )

    # -- run-service (internal; invoked by the systemd service unit) ---------
    sub.add_parser(
        "run-service",
        help=argparse.SUPPRESS,
        description=(
            "Internal entrypoint called by the systemd service unit. Iterates "
            f"{REPOS_CONFIG} and runs cleanup for each project that is due "
            "based on its configured commit cadence."
        ),
        formatter_class=HelpFormatter,
    )

    return parser.parse_args()


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def run(
    cmd: list[str], *, check: bool = True, capture: bool = False
) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, check=check, text=True, capture_output=capture)


def find_beads_dir(project_dir: Path | None = None) -> Path:
    if project_dir is not None:
        candidate = project_dir / ".beads"
        if not candidate.is_dir():
            sys.exit(f"bd-timew: no .beads/ directory found under {project_dir}")
        return candidate
    result = run(["bd", "where"], check=False, capture=True)
    if result.returncode != 0:
        sys.exit(
            "bd-timew: no active Beads workspace. cd into a project with "
            ".beads/, or pass --project-dir."
        )
    return Path(result.stdout.strip().split("\n", 1)[0].strip())


def load_sidecar(beads_dir: Path) -> dict:
    path = beads_dir / "bd-timew.yaml"
    if not path.exists():
        _root_log.warning("no sidecar at %s; using minimal defaults", path)
        return {"default": {}, "patterns": []}
    with path.open() as f:
        data = yaml.safe_load(f) or {}
    data.setdefault("default", {})
    data.setdefault("patterns", [])
    return data


def get_issue(issue_id: str) -> dict:
    result = run(["bd", "show", issue_id, "--json"], check=False, capture=True)
    if result.returncode != 0:
        sys.exit(f"bd-timew: `bd show {issue_id}` failed:\n{result.stderr}")
    data = json.loads(result.stdout)
    if isinstance(data, list):
        if not data:
            sys.exit(f"bd-timew: issue {issue_id} not found")
        return data[0]
    return data


def resolve_tuple(labels: list[str], sidecar: dict) -> dict:
    default = dict(sidecar.get("default") or {})
    tuple_: dict[str, str | None] = {
        "client": default.get("client"),
        "case": default.get("case"),
        "svc": default.get("svc") or GLOBAL_SVC_DEFAULT,
    }
    label_str = " ".join(labels)
    for rule in sidecar.get("patterns") or []:
        pattern = rule.get("match")
        if not pattern:
            continue
        m = re.search(pattern, label_str)
        if m:
            groups = m.groupdict()
            for key in ("client", "case", "svc"):
                if key in rule:
                    val = rule[key]
                    if groups and isinstance(val, str):
                        val = val.format(**groups)
                    tuple_[key] = val
            break
    for label in labels:
        if label.startswith("case:"):
            tuple_["case"] = label[len("case:"):]
            break
    return tuple_


# ---------------------------------------------------------------------------
# Subcommand implementations
# ---------------------------------------------------------------------------

def cmd_start(issue_id: str, *, dry_run: bool = False) -> None:
    beads_dir = find_beads_dir()
    sidecar = load_sidecar(beads_dir)
    issue = get_issue(issue_id)
    labels: list[str] = issue.get("labels") or []
    tuple_ = resolve_tuple(labels, sidecar)

    _root_log.info("Issue:  %s  %s", issue.get("id", "?"), issue.get("title", ""))
    _root_log.info("Labels: %s", ", ".join(labels) or "(none)")
    _root_log.info("Client: %s", tuple_["client"] or "(none)")
    _root_log.info("Case:   %s", tuple_["case"] or "(none)")
    _root_log.info("Svc:    %s", tuple_["svc"] or "(none)")

    if dry_run:
        return

    tags = [issue_id]
    for key in ("client", "case", "svc"):
        val = tuple_[key]
        if val:
            tags.append(f"{key}:{val}")
    if tuple_["svc"] == "none":
        tags.append("billable:false")

    run(["timew", "start", *tags])
    title = issue.get("title", "")
    if title:
        run(["timew", "annotate", f"{issue_id}: {title}"])
    if issue.get("status") != "in_progress":
        run(["bd", "update", issue_id, "--claim"], check=False)


def cmd_stop() -> None:
    run(["timew", "stop"], check=False)


def cmd_switch(issue_id: str) -> None:
    cmd_stop()
    cmd_start(issue_id)


def _timew_get(key: str) -> str | None:
    result = run(["timew", "get", key], check=False, capture=True)
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def _format_elapsed(start_iso: str) -> str:
    compact = re.fullmatch(r"(\d{8})T(\d{6})Z", start_iso)
    if compact:
        date_part, time_part = compact.groups()
        start = dt.datetime.strptime(
            f"{date_part}T{time_part}Z", "%Y%m%dT%H%M%SZ"
        ).replace(tzinfo=dt.timezone.utc)
        now = dt.datetime.now(dt.timezone.utc)
    else:
        start = dt.datetime.fromisoformat(start_iso.replace("Z", "+00:00"))
        now = (
            dt.datetime.now(dt.timezone.utc)
            if start.tzinfo
            else dt.datetime.now()
        )
    delta = now - start
    total_seconds = int(delta.total_seconds())
    hours, remainder = divmod(total_seconds, 3600)
    minutes, _ = divmod(remainder, 60)
    return f"{hours}h {minutes:02d}m" if hours else f"{minutes}m"


def cmd_status() -> None:
    start_iso = _timew_get("dom.active.start")
    if not start_iso:
        _root_log.info("no active timew interval")
        return

    tag_count = int(_timew_get("dom.active.tag.count") or "0")
    tags = [
        t for i in range(1, tag_count + 1)
        if (t := _timew_get(f"dom.active.tag.{i}"))
    ]

    bead_id = next((t for t in tags if ":" not in t), None)
    elapsed = _format_elapsed(start_iso)

    if bead_id:
        issue = None
        try:
            issue = get_issue(bead_id)
        except SystemExit:
            pass
        title = (issue or {}).get("title", "")
        status = (issue or {}).get("status", "")
        _root_log.info("Tracking: %s  %s", bead_id, title)
        if status:
            _root_log.info("Status:   %s", status)
    else:
        _root_log.info("Tracking: (no bead tag found on active interval)")

    _root_log.info("Elapsed:  %s", elapsed)

    tuple_display: dict[str, str | None] = {"client": None, "case": None, "svc": None}
    for tag in tags:
        for key in tuple_display:
            if tag.startswith(f"{key}:"):
                tuple_display[key] = tag[len(f"{key}:"):]
    _root_log.info("Client:   %s", tuple_display["client"] or "(none)")
    _root_log.info("Case:     %s", tuple_display["case"] or "(none)")
    _root_log.info("Svc:      %s", tuple_display["svc"] or "(none)")


def cmd_cleanup(
    days: int,
    *,
    commit: bool = False,
    project_dir: Path | None = None,
) -> None:
    beads_dir = find_beads_dir(project_dir)
    log = logging.LoggerAdapter(
        _cleanup_log,
        extra={"project": str(beads_dir.parent)},
    )
    bd = ["bd", "--db", str(beads_dir / "embeddeddolt" / beads_dir.parent.name)]

    log.info("Starting cleanup (days=%d, commit=%s)", days, commit)

    if commit:
        log.info("Phase 1/3: dolt commit")
        result = run([*bd, "dolt", "commit"], check=False, capture=True)
        if result.returncode != 0:
            log.warning(
                "dolt commit: %s",
                result.stderr.strip() or result.stdout.strip(),
            )
        else:
            log.info("dolt commit: %s", result.stdout.strip())
    else:
        log.info("Phase 1/3: dolt commit (skipped — pass --commit to include)")

    log.info("Phase 2/3: compact --days %d", days)
    result = run(
        [*bd, "compact", f"--days={days}", "--force"], check=False, capture=True
    )
    if result.returncode != 0:
        log.error("compact failed: %s", result.stderr.strip())
    else:
        log.info("compact: %s", result.stdout.strip())

    log.info("Phase 3/3: gc")
    result = run(
        [*bd, "gc", "--skip-decay", "--force"], check=False, capture=True
    )
    if result.returncode != 0:
        log.error("gc failed: %s", result.stderr.strip())
    else:
        log.info("gc: %s", result.stdout.strip())

    log.info("Cleanup complete")


# ---------------------------------------------------------------------------
# Repos config and state helpers
# ---------------------------------------------------------------------------

def _load_repos_config() -> dict:
    if not REPOS_CONFIG.exists():
        return {"global": {}, "repos": []}
    with REPOS_CONFIG.open() as f:
        data = yaml.safe_load(f) or {}
    data.setdefault("global", {})
    data.setdefault("repos", [])
    return data


def _save_repos_config(data: dict) -> None:
    REPOS_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    with REPOS_CONFIG.open("w") as f:
        yaml.dump(data, f, default_flow_style=False, allow_unicode=True)


def _load_cleanup_state() -> dict:
    if not CLEANUP_STATE.exists():
        return {}
    with CLEANUP_STATE.open() as f:
        return json.load(f)


def _save_cleanup_state(state: dict) -> None:
    CLEANUP_STATE.parent.mkdir(parents=True, exist_ok=True)
    with CLEANUP_STATE.open("w") as f:
        json.dump(state, f, indent=2, default=str)


def _parse_cadence(cadence_str: str) -> dt.timedelta:
    """Parse a cadence string like '1d', '7d', '12h' into a timedelta."""
    m = re.fullmatch(r"(\d+)([dhm])", cadence_str.strip())
    if not m:
        sys.exit(
            f"bd-timew: invalid cadence '{cadence_str}' — use e.g. 1d, 7d, 12h"
        )
    value, unit = int(m.group(1)), m.group(2)
    return {
        "d": dt.timedelta(days=value),
        "h": dt.timedelta(hours=value),
        "m": dt.timedelta(minutes=value),
    }[unit]


