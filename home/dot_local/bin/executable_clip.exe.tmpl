{{- if eq .chezmoi.os "linux" -}}
{{- if (.chezmoi.kernel.osrelease | lower | contains "wsl" ) -}}
#!/bin/sh
# Wrapper around Microsoft clip.exe
# This makes it possible to call clip.exe without adding /mnt/c/Windows/system32 to PATH

exec /mnt/c/Windows/system32/clip.exe "$@"
{{- end }}
{{- end }}
