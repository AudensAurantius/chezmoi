{{- if eq .chezmoi.os "linux" -}}
{{- if (.chezmoi.kernel.osrelease | lower | contains "wsl" ) -}}
#!/bin/sh
# Wrapper around Microsoft ipconfig.exe
# This makes it possible to call ipconfig.exe without adding /mnt/c/Windows/system32 to PATH

exec /mnt/c/Windows/System32/ipconfig.exe "$@"
{{- end }}
{{- end }}
