{{- if eq .chezmoi.os "linux" -}}
{{- if (.chezmoi.kernel.osrelease | lower | contains "wsl" ) -}}
#!/bin/sh
# Wrapper around Microsoft powershell.exe
# This makes it possible to call powershell.exe without adding /mnt/c/Windows/System32/WindowsPowerShell/v1.0 to PATH

exec /mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe "$@"
{{- end }}
{{- end }}
