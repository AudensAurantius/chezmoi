#!/usr/bin/env bash
# Tear down the VPN network namespace and clean up all associated state.
# Must run as root (sudo vpn-disconnect).

set -euo pipefail

NS="vpn"
VETH_HOST="veth-vpn"
NET="10.200.0.0/24"
HOST_IF="eth0"
PIDFILE="/run/vpn-openvpn.pid"

[[ "$(id -u)" -eq 0 ]] || { echo "vpn-disconnect: must run as root (use sudo)" >&2; exit 1; }

errors=0

if [[ -f "$PIDFILE" ]]; then
  pid=$(cat "$PIDFILE")
  if kill -0 "$pid" 2>/dev/null; then
    echo "Stopping OpenVPN (pid $pid)..." >&2
    kill "$pid" && sleep 1 || { echo "vpn-disconnect: failed to kill OpenVPN" >&2; errors=1; }
  fi
  rm -f "$PIDFILE"
else
  echo "vpn-disconnect: no PID file at $PIDFILE — OpenVPN may not be running" >&2
fi

echo "Removing NAT rule..." >&2
iptables -t nat -D POSTROUTING -s "$NET" -o "$HOST_IF" -j MASQUERADE 2>/dev/null || true

echo "Disabling IP forwarding..." >&2
sysctl -qw net.ipv4.ip_forward=0

echo "Deleting namespace '$NS'..." >&2
if ip netns list | grep -q "^${NS}\b"; then
  ip netns del "$NS"   # also removes the veth pair
  rm -rf "/etc/netns/$NS"
else
  echo "vpn-disconnect: namespace '$NS' not found — already torn down?" >&2
  ip link del "$VETH_HOST" 2>/dev/null || true
fi

shred -u /tmp/vpn-auth-* 2>/dev/null || true

if [[ $errors -eq 0 ]]; then
  echo "VPN disconnected." >&2
else
  echo "vpn-disconnect: completed with errors (see above)." >&2
  exit 1
fi
