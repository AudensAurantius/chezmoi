#!/usr/bin/env bash
# Run a command inside the VPN network namespace.
# Usage: vpn-exec <command> [args...]
# Example: vpn-exec snow connection test -c J121-prod

set -euo pipefail

NS="vpn"

[[ $# -gt 0 ]] || { echo "usage: vpn-exec <command> [args...]" >&2; exit 1; }

ip netns list 2>/dev/null | grep -q "^${NS}\b" || {
  echo "vpn-exec: namespace '$NS' not found — run 'sudo vpn-connect' first" >&2
  exit 1
}

exec sudo ip netns exec "$NS" sudo -u "$USER" "$@"
