#!/usr/bin/env bash
# OpenVPN --up/--down hook for the WSL2 network namespace VPN.
# Direct replacement for update-resolv-conf; writes pushed DNS directly to
# /etc/resolv.conf. Inside the mount namespace created by `ip netns exec`,
# /etc/resolv.conf resolves to /etc/netns/vpn/resolv.conf on the host —
# so this only affects DNS inside the tunnel, not on the host.
#
# OpenVPN calls this with $script_type=up|down and foreign_option_N env vars
# set to the server-pushed dhcp-option values, e.g.:
#   foreign_option_1="dhcp-option DNS 10.255.255.254"
#   foreign_option_2="dhcp-option DOMAIN boldorange.local"
#
# compgen -v 'prefix' lists all variable names starting with 'prefix' —
# a bash built-in that avoids having to hard-code an index upper bound.

set -euo pipefail

RESOLV="/etc/resolv.conf"

case "${script_type:-}" in
  up)
    nameservers=()
    domains=()
    while IFS= read -r var; do
      opt="${!var}"
      case "$opt" in
        "dhcp-option DNS "*)    nameservers+=("${opt#dhcp-option DNS }") ;;
        "dhcp-option DOMAIN "*) domains+=("${opt#dhcp-option DOMAIN }") ;;
      esac
    done < <(compgen -v 'foreign_option_' | sort)

    {
      if [[ ${#nameservers[@]} -gt 0 ]]; then
        for ns in "${nameservers[@]}"; do echo "nameserver $ns"; done
      else
        echo "nameserver 8.8.8.8"
        echo "nameserver 1.1.1.1"
      fi
      [[ ${#domains[@]} -gt 0 ]] && echo "search ${domains[*]}"
    } > "$RESOLV"
    ;;
  down)
    printf 'nameserver 8.8.8.8\nnameserver 1.1.1.1\n' > "$RESOLV"
    ;;
  *)
    echo "vpn-ns-dns: unexpected script_type '${script_type:-}'" >&2
    exit 1
    ;;
esac
