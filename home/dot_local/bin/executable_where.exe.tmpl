{{- if eq .chezmoi.os "linux" -}}
{{- if (.chezmoi.kernel.osrelease | lower | contains "wsl" ) -}}
#!/bin/sh
# Wrapper around Microsoft where.exe
# This makes it possible to call where.exe without adding /mnt/c/Windows/system32 to PATH
# Useful for finding the location of Windows executables

/mnt/c/Windows/system32/where.exe "$@"
{{- end }}
{{- end }}
