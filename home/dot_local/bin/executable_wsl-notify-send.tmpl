{{ if and (.chezmoi.kernel.osrelease | lower | contains "wsl") (lookPath "cmd.exe") -}}
#!/usr/bin/env bash
# wsl-notify-send: WSL2 notification shim.
#
# Uses BurntToast (PowerShell) when installed — supports rich flags (scenario,
# group/replace, image, header, buttons). Falls back to wsl-notify-send.exe
# for basic title+body toasts when BurntToast is absent.
#
# Usage: wsl-notify-send [flags] <title> [body]
#        wsl-notify-send [flags] --config <file>
#        wsl-notify-send [flags] --config -        # read JSON config from stdin
#        wsl-notify-send --help
#
# Flags:
#   -h, --help               show this help and exit
#   --scenario <default|reminder|alarm|incomingCall>
#   --group <id>             same id replaces rather than stacks toasts
#   --image <windows-path>   image displayed in the toast
#   --header <id=title>      conversation header grouping
#   --button <label=action>  action button; action: dismiss | snooze | <url>
#                            repeatable; multiple --button flags are cumulative
#   --config <file>          read settings from a JSON file (or '-' for stdin)
#
# JSON config file shape (all keys optional; arrays for buttons):
#   {
#     "title":    "...",
#     "body":     "...",
#     "scenario": "reminder",
#     "group":    "...",
#     "image":    "/win/path",
#     "header":   "id=title",
#     "buttons":  ["label1", "label2=action2", ...]
#   }
#
# Precedence (when --config is combined with CLI flags / positionals):
#   - Scalars (title/body/scenario/group/image/header):
#       CLI flag or positional wins; config provides defaults for fields
#       the CLI didn't supply.
#   - Buttons (array):
#       Config's buttons come first, CLI --button flags are appended after.
#       Order: [config buttons..., cli buttons...]
#
# Installation of wsl-notify-send.exe (fallback):
#   See J121 memory feedback-time-tracking.md — exe lives at %USERPROFILE%\bin\

set -euo pipefail

INSTALL_SUBPATH="bin/wsl-notify-send.exe"

# Print the docstring above as the help text. ${BASH_SOURCE[0]} is preferred
# over $0 here so this works correctly if the script is ever sourced rather
# than executed (e.g. for testing).
usage() {
    sed -n '/^# Usage:/,/^$/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

# ── Flag parsing ──────────────────────────────────────────────────────────────
# Track which scalar flags were explicitly given so --config can adopt only
# the unset ones rather than overwriting CLI intent.

scenario="Default"; scenario_set=false
group="";           group_set=false
image="";           image_set=false
header="";          header_set=false
buttons=()
config_file=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)  usage; exit 0 ;;
        --scenario) scenario="$2"; scenario_set=true; shift 2 ;;
        --group)    group="$2";    group_set=true;    shift 2 ;;
        --image)    image="$2";    image_set=true;    shift 2 ;;
        --header)   header="$2";   header_set=true;   shift 2 ;;
        --button)   buttons+=("$2"); shift 2 ;;
        --config)   config_file="$2"; shift 2 ;;
        --)         shift; break ;;
        -*)         echo "wsl-notify-send: unknown flag: $1" >&2; exit 1 ;;
        *)          break ;;
    esac
done

title="";  title_set=false
body="";   body_set=false
[ $# -ge 1 ] && { title="$1"; title_set=true; }
[ $# -ge 2 ] && { body="$2";  body_set=true;  }

# ── --config handling ─────────────────────────────────────────────────────────
# Scalars: CLI wins; config fills in unset fields.
# Buttons: config's array first, CLI-collected --button flags appended after.
#
# Note on `${arr[@]+"${arr[@]}"}` array expansion below:
#   The leading `+` is bash's "set-or-default" parameter expansion: if `arr`
#   is set, expand to its elements; if unset, expand to nothing. It's a
#   defensive idiom against a bash 4.0–4.3 bug where `"${arr[@]}"` on an
#   empty array under `set -u` raised "unbound variable". Fixed in bash 4.4
#   (Oct 2016), so it's redundant on modern systems — but cheap insurance
#   and recognizable to anyone who's debugged scripts on RHEL 7-era boxes.

if [ -n "$config_file" ]; then
    if ! command -v jq >/dev/null 2>&1; then
        echo "wsl-notify-send: --config requires jq on PATH" >&2
        exit 1
    fi
    if [ "$config_file" = "-" ]; then
        cfg_json=$(cat)
    elif [ -f "$config_file" ]; then
        cfg_json=$(cat "$config_file")
    else
        echo "wsl-notify-send: config file not found: $config_file" >&2
        exit 1
    fi

    _fld() { jq -r --arg k "$1" '.[$k] // empty' <<<"$cfg_json"; }

    if [ "$title_set"    = false ]; then v=$(_fld title);    [ -n "$v" ] && title="$v";    fi
    if [ "$body_set"     = false ]; then v=$(_fld body);     [ -n "$v" ] && body="$v";     fi
    if [ "$scenario_set" = false ]; then v=$(_fld scenario); [ -n "$v" ] && scenario="$v"; fi
    if [ "$group_set"    = false ]; then v=$(_fld group);    [ -n "$v" ] && group="$v";    fi
    if [ "$image_set"    = false ]; then v=$(_fld image);    [ -n "$v" ] && image="$v";    fi
    if [ "$header_set"   = false ]; then v=$(_fld header);   [ -n "$v" ] && header="$v";   fi

    if [ "$(jq 'has("buttons") and (.buttons | type == "array") and (.buttons | length > 0)' <<<"$cfg_json")" = "true" ]; then
        mapfile -t config_buttons < <(jq -r '.buttons[]' <<<"$cfg_json")
        buttons=("${config_buttons[@]+"${config_buttons[@]}"}" "${buttons[@]+"${buttons[@]}"}")
    fi
fi

# Final defaults if neither CLI nor config supplied a title.
[ -z "$title" ] && title="notification"

# ── Resolve Windows USERPROFILE ───────────────────────────────────────────────

WINPROFILE="$(wslpath "$(cmd.exe /C 'echo %USERPROFILE%' 2>/dev/null | tr -d '\r')")"

# ── BurntToast availability (filesystem check — no powershell.exe call) ──────

burnttoast_available=false
for bt_path in \
    "${WINPROFILE}/Documents/WindowsPowerShell/Modules/BurntToast" \
    "${WINPROFILE}/Documents/PowerShell/Modules/BurntToast"; do
    if [ -d "$bt_path" ]; then
        burnttoast_available=true
        break
    fi
done

# ── BurntToast backend ────────────────────────────────────────────────────────

if [ "$burnttoast_available" = true ]; then
    # Encode multiple buttons as a pipe-separated string: "Label1=action1|Label2=action2"
    buttons_env=""
    for btn in "${buttons[@]+"${buttons[@]}"}"; do
        buttons_env="${buttons_env:+${buttons_env}|}${btn}"
    done

    # WSL2 only forwards env vars listed in WSLENV to Windows processes.
    WSLENV="NOTIFY_TITLE:NOTIFY_BODY:NOTIFY_SCENARIO:NOTIFY_GROUP:NOTIFY_IMAGE:NOTIFY_HEADER:NOTIFY_BUTTONS" \
    NOTIFY_TITLE="$title" \
    NOTIFY_BODY="$body" \
    NOTIFY_SCENARIO="$scenario" \
    NOTIFY_GROUP="$group" \
    NOTIFY_IMAGE="$image" \
    NOTIFY_HEADER="$header" \
    NOTIFY_BUTTONS="$buttons_env" \
    powershell.exe -NoProfile -NonInteractive -Command '
        Import-Module BurntToast -ErrorAction Stop

        $textArr = @($env:NOTIFY_TITLE)
        if ($env:NOTIFY_BODY) { $textArr = $textArr + @($env:NOTIFY_BODY) }

        $params = @{ Text = $textArr }

        # BurntToast 1.x has no -Scenario; map to -Sound and -Urgent equivalents.
        # Null-safe: WSLENV may be unset in some call contexts.
        $scenario = if ($env:NOTIFY_SCENARIO) { $env:NOTIFY_SCENARIO.ToLower() } else { "" }
        switch ($scenario) {
            "reminder"     { $params.Sound = "Reminder" }
            "alarm"        { $params.Sound = "Alarm"; $params.Urgent = $true }
            "incomingcall" { $params.Sound = "Call";  $params.Urgent = $true }
        }

        if ($env:NOTIFY_GROUP)  { $params.UniqueIdentifier = $env:NOTIFY_GROUP }
        if ($env:NOTIFY_IMAGE)  { $params.AppLogo = $env:NOTIFY_IMAGE }

        if ($env:NOTIFY_HEADER) {
            $parts  = $env:NOTIFY_HEADER -split "=", 2
            $hId    = $parts[0]
            $hTitle = if ($parts.Count -gt 1) { $parts[1] } else { $parts[0] }
            $params.Header = New-BTHeader -Id $hId -Title $hTitle
        }

        if ($env:NOTIFY_BUTTONS) {
            $btns = @()
            foreach ($spec in ($env:NOTIFY_BUTTONS -split "\|")) {
                $bParts  = $spec -split "=", 2
                $bLabel  = $bParts[0]
                $bAction = if ($bParts.Count -gt 1) { $bParts[1] } else { "dismiss" }
                if ($bAction -eq "dismiss") {
                    $btns += New-BTButton -Content $bLabel -Dismiss
                } elseif ($bAction -eq "snooze") {
                    $btns += New-BTButton -Content $bLabel -Snooze
                } else {
                    $btns += New-BTButton -Content $bLabel -Arguments $bAction
                }
            }
            $params.Button = $btns
        }

        New-BurntToastNotification @params
    ' 2>/dev/null && exit 0
    # fall through on powershell error (e.g. module missing despite dir check)
fi

# ── wsl-notify-send.exe fallback ──────────────────────────────────────────────

WNS_EXE="${WINPROFILE}/${INSTALL_SUBPATH}"

if [ ! -x "$WNS_EXE" ]; then
    echo "wsl-notify-send: $WNS_EXE not found or not executable" >&2
    exit 1
fi

if [ -n "$body" ]; then
    msg="${title}: ${body}"
else
    msg="$title"
fi

exec "$WNS_EXE" "$msg"
{{- end }}
