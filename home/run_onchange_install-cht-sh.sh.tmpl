#!/bin/sh
# run_onchange_install-cht-sh.sh.tmpl — install cht.sh to ~/.local/bin.
#
# cht.sh has no upstream release tags — it's rolling from master. Pin is
# SHA256-first: `.chezmoidata/cht-sh.yaml` stores the date captured plus
# the hash of the fetched script. Bumping the hash triggers re-install.
#
# The zsh completion (`home/dot_local/share/zsh/completions/_cht`) is a
# static file committed into chezmoi source, NOT regenerated by this
# installer. Refresh manually when bumping the script if you want both in
# sync — see .chezmoidata/cht-sh.yaml for the procedure.
{{- $v := .chtSh.version -}}
{{- $sha := .chtSh.sha256 }}

set -eu

VERSION={{ $v | quote }}
EXPECTED_SHA={{ $sha | quote }}
ASSET_URL="https://cht.sh/:cht.sh"
INSTALL_PATH={{ joinPath .chezmoi.homeDir ".local" "bin" "cht.sh" | quote }}

# Idempotency guard — SHA256 of installed script matches pinned hash.
if [ -x "$INSTALL_PATH" ] \
    && [ "$(sha256sum "$INSTALL_PATH" 2>/dev/null | awk '{print $1}')" = "$EXPECTED_SHA" ]; then
  echo "cht.sh installer: pin $VERSION already installed at $INSTALL_PATH" >&2
  exit 0
fi

mkdir -p "$(dirname "$INSTALL_PATH")"

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

echo "cht.sh installer: downloading $ASSET_URL" >&2
curl -fsSL -o "$tmp" "$ASSET_URL"

actual=$(sha256sum "$tmp" | awk '{print $1}')
if [ "$EXPECTED_SHA" != "$actual" ]; then
  echo "cht.sh installer: checksum mismatch — upstream rolled since last pin" >&2
  echo "  expected: $EXPECTED_SHA" >&2
  echo "  actual:   $actual" >&2
  echo "  to refresh: bump .chezmoidata/cht-sh.yaml with the new hash" >&2
  exit 1
fi

chmod u+x "$tmp"
mv "$tmp" "$INSTALL_PATH"
echo "cht.sh installer: pin $VERSION installed to $INSTALL_PATH" >&2
